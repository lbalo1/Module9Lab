@page
@model ProductsModel
@{
    ViewData["Title"] = "Northwind Products";
}

<!-- Displays the page title --> 
<h1>@ViewData["Title"]</h1>

<!-- Table to show product data --> 
<table class="table">
    <thead>
        <tr>
            <th>Product Name</th>
            <th>Category</th>
            <th>Unit Price</th>
        </tr>
    </thead>
    <tbody>
        <!-- Loop through each product in the list --> 
        @foreach (var product in Model.Products)
        {
            <tr> 
                <!-- Show product name -->
                <td>@product.ProductName</td> 
                <!-- Show category name -->
                <td>@product.CategoryName</td>
                <!-- Show price --> 
                <td>@product.UnitPrice.ToString("C")</td>
            </tr>
        }
    </tbody>
</table>